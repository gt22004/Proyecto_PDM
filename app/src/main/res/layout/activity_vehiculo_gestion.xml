<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".vehiculo.VehiculoGestionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_gestion_vehiculos"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_id_vehiculo"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editIdVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_id_vehiculo"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_marca"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editMarca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_marca"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_modelo"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editModelo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_modelo"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_anio"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editAnio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_anio"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_id_importacion"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editIdImportacionVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_id_importacion"
            android:inputType="number"
            android:layout_marginBottom="24dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <Button
                android:id="@+id/btnInsertarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_save"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnConsultarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_search"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnActualizarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_update"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnEliminarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_delete"
                android:backgroundTint="#FF5252"
                android:textColor="#FFFFFF"
                android:layout_margin="4dp"/>
        </GridLayout>

        <Button
            android:id="@+id/btnLimpiarVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_clean"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btnIrAEstadoVehicular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_estado_vehicular"
            android:layout_marginTop="12dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>