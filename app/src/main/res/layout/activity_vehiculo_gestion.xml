<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".vehiculo.VehiculoGestionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gestión de Vehículos"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ID Vehículo"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editIdVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ID único del vehículo"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Marca"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editMarca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej. Toyota"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modelo"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editModelo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej. Corolla"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Año"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editAnio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej. 2024"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ID Importación"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editIdImportacionVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ID de la importación vinculada"
            android:inputType="number"
            android:layout_marginBottom="24dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <Button
                android:id="@+id/btnInsertarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="INSERTAR"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnConsultarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="CONSULTAR"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnActualizarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="ACTUALIZAR"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnEliminarVehiculo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="ELIMINAR"
                android:backgroundTint="#FF5252"
                android:textColor="#FFFFFF"
                android:layout_margin="4dp"/>
        </GridLayout>

        <Button
            android:id="@+id/btnLimpiarVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIMPIAR"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>