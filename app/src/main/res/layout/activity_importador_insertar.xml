<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".importador.ImportadorInsertarActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_insert_importador"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nui"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorNUI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: IMP0000001"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nombre"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_nombre"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_apellido"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorApellido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_apellido"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_apellido_casada"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorApellidoCasada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_apellido_casada"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_genero"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerImportadorGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_fecha_nacimiento"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_fecha_nacimiento"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_direccion"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_direccion"
            android:inputType="textMultiLine"
            android:lines="2"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_correo"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="correo@ejemplo.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nui_responsable"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorNUIResponsable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_nui_responsable"
            android:inputType="text"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnGuardarImportador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save"/>

        <Button
            android:id="@+id/btnLimpiarImportador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_clean"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>