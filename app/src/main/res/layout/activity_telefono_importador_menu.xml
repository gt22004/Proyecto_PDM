<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    tools:context=".importador.TelefonoImportadorMenuActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestión de Teléfonos"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnTelefonoInsertar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="INSERTAR TELÉFONO"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnTelefonoConsultar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CONSULTAR TELÉFONOS"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnTelefonoActualizar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="ACTUALIZAR TELÉFONO"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnTelefonoEliminar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="ELIMINAR TELÉFONO"
        android:backgroundTint="#FF5252"
        android:textColor="#FFFFFF"/>

</LinearLayout>