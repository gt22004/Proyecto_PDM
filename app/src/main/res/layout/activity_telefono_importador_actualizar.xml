<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".importador.TelefonoImportadorActualizarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_update_phone"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/editActualizarTelefonoId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_phone_id"
            android:inputType="number"/>

        <Button
            android:id="@+id/btnCargarTelefono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_load"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_phone_number"
        android:textStyle="bold"/>
    <EditText
        android:id="@+id/editActualizarTelefonoNumero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_phone_number"
        android:inputType="phone"
        android:layout_marginBottom="12dp"
        android:enabled="false"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_phone_type"
        android:textStyle="bold"/>
    <Spinner
        android:id="@+id/spinnerActualizarTelefonoTipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:enabled="false"/>

    <Button
        android:id="@+id/btnActualizarTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_save_changes"
        android:enabled="false"/>

    <Button
        android:id="@+id/btnLimpiarActualizarTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_clean"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginTop="8dp"/>

</LinearLayout>