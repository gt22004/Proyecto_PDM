<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".importador.TelefonoImportadorInsertarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Insertar Teléfono"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NUI del Importador*"
        android:textStyle="bold"/>
    <EditText
        android:id="@+id/editTelefonoNUI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="NUI del importador"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Número de Teléfono*"
        android:textStyle="bold"/>
    <EditText
        android:id="@+id/editTelefonoNumero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: 7777-8888"
        android:inputType="phone"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tipo de Teléfono"
        android:textStyle="bold"/>
    <Spinner
        android:id="@+id/spinnerTelefonoTipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnGuardarTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GUARDAR TELÉFONO"/>

    <Button
        android:id="@+id/btnLimpiarTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LIMPIAR CAMPOS"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginTop="8dp"/>

</LinearLayout>