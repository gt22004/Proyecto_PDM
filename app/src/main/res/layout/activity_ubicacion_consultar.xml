<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ubicacion.UbicacionConsultarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Consultar Ubicación"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/editConsultarIdUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ID de Ubicación"
        android:inputType="number"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnConsultarUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Consultar" />

    <TextView
        android:id="@+id/textResultadoUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resultado..."
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        android:padding="8dp"
        android:background="#F0F0F0"/>

</LinearLayout>
