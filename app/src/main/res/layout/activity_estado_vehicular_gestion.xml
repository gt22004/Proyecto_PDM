<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".estadovehicular.EstadoVehicularGestionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado Vehicular"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Seleccione Vehículo (VIN)"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerVehiculoEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Historial de Estados (por fecha)"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerHistorialEstados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción del Estado"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editDescripcionEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej. Abolladura en puerta"
            android:inputType="textMultiLine"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha del Registro"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editFechaEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccione Fecha"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fotografía"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:id="@+id/imgVehiculoEstado"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#EEEEEE"
            android:scaleType="centerInside"
            android:layout_marginBottom="8dp"
            android:contentDescription="Imagen del estado"/>

        <Button
            android:id="@+id/btnSeleccionarImagen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CAMBIAR IMAGEN"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginBottom="24dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <Button
                android:id="@+id/btnInsertarEstado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="INSERTAR NUEVO"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnConsultarEstado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="RECARGAR"
                android:layout_margin="4dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnActualizarEstado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="ACTUALIZAR"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnEliminarEstado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="ELIMINAR"
                android:backgroundTint="#FF5252"
                android:textColor="#FFFFFF"
                android:layout_margin="4dp"/>
        </GridLayout>

        <Button
            android:id="@+id/btnLimpiarEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIMPIAR CAMPOS"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>