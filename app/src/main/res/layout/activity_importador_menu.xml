<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    tools:context=".importador.ImportadorMenuActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_importadores_menu"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnImportadorInsertar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_insert_importador"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnImportadorConsultar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_consult_importador"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnImportadorActualizar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_update_importador"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnImportadorEliminar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_delete_importador"
        android:backgroundTint="#FF5252"
        android:textColor="#FFFFFF"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginVertical="16dp"/>

    <Button
        android:id="@+id/btnTelefonosImportador"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_manage_phones"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

</LinearLayout>