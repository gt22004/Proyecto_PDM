<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".seccion.SeccionInsertarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Insertar Nueva Sección"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccione Bodega:"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerBodegas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/editNivel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nivel (Número)"
        android:inputType="number"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/editCapacidadSeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Capacidad Máxima de Vehículos"
        android:inputType="number"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnGuardarSeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar Sección" />

    <Button
        android:id="@+id/btnLimpiarSeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Limpiar Campos"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginTop="8dp"/>

</LinearLayout>
