<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".importador.ImportadorActualizarActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_actualizar_importador"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <EditText
                android:id="@+id/editActualizarNUI"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/label_nui"
                android:inputType="text"/>
            <Button
                android:id="@+id/btnCargarImportador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_load"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nombre"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editActualizarNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_nombre"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_apellido"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editActualizarApellido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_apellido"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_apellido_casada"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editActualizarApellidoCasada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_apellido_casada"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_genero"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerActualizarGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_fecha_nacimiento"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editActualizarFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_fecha_nacimiento"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_direccion"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editActualizarDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_direccion"
            android:inputType="textMultiLine"
            android:lines="2"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_correo"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editActualizarCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="correo@ejemplo.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nui_responsable"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editActualizarNUIResponsable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_nui_responsable"
            android:inputType="text"
            android:layout_marginBottom="24dp"
            android:enabled="false"/>

        <Button
            android:id="@+id/btnActualizarImportador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_changes"
            android:enabled="false"/>

        <Button
            android:id="@+id/btnLimpiarActualizarImportador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_clean"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>