<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".gastos.GastoAdicionalGestionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_gestion_gastos"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_seleccione_vehiculo"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerVehiculoGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_historial_gastos"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerHistorialGastos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_id_gasto"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editIdGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_enter_id"
            android:inputType="number"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_concepto"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editConceptoGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej. Pago de Aduana"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_monto"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editMontoGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="0.00"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_fecha_gasto"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editFechaGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="YYYY-MM-DD"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="24dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <Button
                android:id="@+id/btnInsertarGasto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_insertar_gasto"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnConsultarGasto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_consultar_gasto"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnActualizarGasto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_actualizar_gasto"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnEliminarGasto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_eliminar_gasto"
                android:backgroundTint="#FF5252"
                android:textColor="#FFFFFF"
                android:layout_margin="4dp"/>
        </GridLayout>

        <Button
            android:id="@+id/btnLimpiarGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_clean"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>
