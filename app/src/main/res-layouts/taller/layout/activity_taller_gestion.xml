<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_gestion_talleres"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/auto_import_dark"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnIrACrear"
            style="@style/AutoImportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_new_taller"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_id_label"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/editBusquedaId"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />

        <Button
            android:id="@+id/btnBuscar"
            style="@style/AutoImportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_search_record" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/auto_import_border_grey"
            android:layout_marginVertical="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nombre_taller"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editNombre"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_direccion"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editDireccion"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_telefono"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editTelefono"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_autorizado"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editAutorizado"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnActualizar"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_update"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnEliminar"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_delete"
                android:backgroundTint="#888888"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/listado_talleres"
            android:textStyle="bold"
            android:textColor="@color/auto_import_dark"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTalleres"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
