<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GESTIÓN DE REPARACIONES"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/auto_import_dark"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnIrACrearRep"
            style="@style/AutoImportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUEVA REPARACIÓN"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ID A BUSCAR"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/editBusquedaRepId"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />

        <Button
            android:id="@+id/btnBuscarRep"
            style="@style/AutoImportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BUSCAR REGISTRO" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/auto_import_border_grey"
            android:layout_marginVertical="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TALLER"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerRepTaller"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VEHÍCULO"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerRepVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FECHA ENTRADA"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editRepFechaEntrada"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="DD/MM/AAAA" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FECHA SALIDA"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editRepFechaSalida"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="DD/MM/AAAA" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DESCRIPCIÓN"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editRepDescripcion"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APTO PARA VENTA (S/N)"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editRepApto"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COSTO"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/editRepCosto"
            style="@style/AutoImportEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnActualizarRep"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ACTUALIZAR"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnEliminarRep"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ELIMINAR"
                android:backgroundTint="#888888"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/listado_reparaciones"
            android:textStyle="bold"
            android:textColor="@color/auto_import_dark"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerReparaciones"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
