<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_edittext_rounded"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtItemNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nombre del Taller"
            android:textStyle="bold"
            android:textColor="@color/auto_import_dark"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/txtItemId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#ID"
            android:textColor="@color/auto_import_red"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txtItemDireccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dirección"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/txtItemTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Teléfono"
        android:textColor="@color/auto_import_text_dark"
        android:textSize="12sp"/>

</LinearLayout>
