<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo"
            android:layout_centerVertical="true"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTOIMPORT"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/auto_import_dark"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- Rejilla de opciones -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:padding="24dp"
        android:alignmentMode="alignMargins">

        <!-- Opción 1: MOVIMIENTOS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrAMovimientosHub"
                style="@style/HubIconButton"
                android:src="@drawable/ic_movimientos"
                android:contentDescription="@string/menu_movimientos"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_movimientos"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Opción 2: VENTA -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrAVentas"
                style="@style/HubIconButton"
                android:src="@drawable/ic_ventas"
                android:contentDescription="@string/menu_ventas"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_ventas"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Opción 3: BODEGAS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrABodega"
                style="@style/HubIconButton"
                android:src="@drawable/ic_movimientos"
                android:contentDescription="@string/menu_bodegas"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_bodegas"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Opción 4: TALLER -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrATaller"
                style="@style/HubIconButton"
                android:src="@drawable/ic_ventas"
                android:contentDescription="@string/desc_talleres"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_talleres"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Opción 5: REPARACIONES -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrAReparaciones"
                style="@style/HubIconButton"
                android:src="@drawable/ic_movimientos"
                android:contentDescription="@string/desc_reparaciones"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_reparaciones"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
          
        <!-- Opción 6: IMPORTADORES -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrAImportadores"
                style="@style/HubIconButton"
                android:src="@drawable/ic_gestion"
                android:contentDescription="@string/menu_importadores"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_importadores"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Opción 7: IMPORTACIONES -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrAImportaciones"
                style="@style/HubIconButton"
                android:src="@drawable/ic_movimientos"
                android:contentDescription="@string/menu_importaciones"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_importaciones"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Opción 8: VEHICULOS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_margin="8dp">

            <ImageButton
                android:id="@+id/btnIrAVehiculo"
                style="@style/HubIconButton"
                android:src="@drawable/ic_movimientos"
                android:contentDescription="@string/menu_vehiculos"
                app:tint="@color/auto_import_dark"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_vehiculos"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/auto_import_text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </GridLayout>

</LinearLayout>
